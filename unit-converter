  <!-- reuse the same styles as before; shortened here to main layout + app box -->
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #020617;
      color: #e5e7eb;
      margin: 0;
    }
    header {
      border-bottom: 1px solid #111827;
      background: #020617;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .container {
      max-width: 960px;
      margin: 0 auto;
      padding: 1rem 1.25rem 2rem;
    }
    .brand {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
      padding: 0.75rem 0;
    }
    .brand-left {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .logo {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: radial-gradient(circle at 30% 30%, #38bdf8, #1d4ed8);
    }
    h1 {
      font-size: 1.25rem;
      margin: 0;
    }
    a.nav-link {
      font-size: 0.86rem;
      color: #93c5fd;
      text-decoration: none;
    }
    a.nav-link:hover { color: #bfdbfe; }

    /* app box & controls – same style you already used */
    .app {
      width: 100%;
      max-width: 780px;
      background: #020617;
      border-radius: 12px;
      padding: 1.5rem 1.8rem 2rem;
      box-shadow: 0 18px 40px rgba(0,0,0,0.6);
      border: 1px solid #111827;
    }
    main .container {
      display: flex;
      justify-content: center;
    }
    p {
      margin-top: 0;
      margin-bottom: 0.75rem;
      font-size: 0.9rem;
      color: #9ca3af;
    }
    label {
      font-size: 0.9rem;
      font-weight: 600;
      display: block;
      margin-bottom: 0.25rem;
      color: #e5e7eb;
    }
    select, input {
      width: 100%;
      padding: 0.5rem 0.6rem;
      border-radius: 0.5rem;
      border: 1px solid #1f2937;
      background: #020617;
      color: #e5e7eb;
      margin-bottom: 0.75rem;
      font-size: 0.95rem;
    }
    select:focus, input:focus {
      outline: 2px solid #2563eb;
      outline-offset: 1px;
      border-color: transparent;
    }
    .row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    button {
      margin-top: 0.5rem;
      width: 100%;
      padding: 0.65rem 1rem;
      border-radius: 999px;
      border: none;
      background: #2563eb;
      color: white;
      font-weight: 600;
      cursor: pointer;
      font-size: 0.95rem;
    }
    button:hover { background: #1d4ed8; }
    .result {
      margin-top: 1rem;
      padding: 0.75rem 1rem;
      border-radius: 0.75rem;
      background: #020617;
      border: 1px solid #1f2937;
      font-size: 1rem;
    }
    .error {
      color: #fca5a5;
      margin-top: 0.5rem;
      font-size: 0.9rem;
    }
    .muted {
      font-size: 0.8rem;
      color: #6b7280;
      margin-top: 0.4rem;
    }
  </style>
</head>
